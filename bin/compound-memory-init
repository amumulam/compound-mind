#!/usr/bin/env node

const { program } = require('commander');
const install = require('../lib/install');
const update = require('../lib/update');

program
  .name('compound-memory-init')
  .description('Install Compound Memory Framework for OpenClaw agents')
  .version('1.0.0');

program
  .option('-a, --agent <name>', 'Agent name (default: "agent")', 'agent')
  .option('-p, --path <path>', 'Custom workspace path')
  .option('--update-ce', 'Update CE Plugin only')
  .option('--update-framework', 'Update framework templates only')
  .option('--skip-cron', 'Skip cron job setup')
  .option('--skip-git', 'Skip git initialization')
  .action(async (options) => {
    try {
      if (options.updateCe) {
        await update.cePlugin();
      } else if (options.updateFramework) {
        await update.framework(options);
      } else {
        await install(options);
      }
    } catch (error) {
      console.error('❌ Error:', error.message);
      process.exit(1);
    }
  });

program.parse();