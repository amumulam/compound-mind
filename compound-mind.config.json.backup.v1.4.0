{
  "version": "1.5.0",
  "name": "compound-mind",
  "cronModel": "bailian-coding-plan/glm-4.7",
  "tasks": {
    "checkpoint": {
      "name": "compound-mind-checkpoint",
      "schedule": "every 6h"
    },
    "compound": {
      "name": "compound-mind-compound",
      "schedule": "0 4 * * *"
    },
    "knowledge": {
      "name": "compound-mind-knowledge",
      "schedule": "30 2 * * 0"
    },
    "optimizer": {
      "name": "compound-mind-optimizer",
      "schedule": "0 3 * * 0"
    },
    "monitor": {
      "name": "compound-mind-monitor",
      "schedule": "0 22 * * *"
    }
  }
}
